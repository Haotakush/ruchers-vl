// ============================================================
//  Firebase Storage — Règles de sécurité Ruchers VL
//  À coller dans : Firebase Console → Storage → Rules
// ============================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Chaque utilisateur ne peut lire/écrire QUE ses propres fichiers.
    // Structure : users/{uid}/ruchers/{rucherId}/{filename}
    //             users/{uid}/visits/{visitId}/{filename}
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Tout le reste est interdit par défaut.
  }
}
